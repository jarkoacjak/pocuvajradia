<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.audio.pocuvam.radio" name="Počúvam Rádio" version="1.0.18" provider-name="Jarko">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>audio</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <language>sk_sk</language>
        <summary lang="sk_sk">Doplnky hudby - Slovenské a České rádiá</summary>
        <description lang="sk_sk">Prehrávač slovenských a českých rádio staníc vytvorený pre Kodi pod názvom Počúvam Rádio.</description>
        <disclaimer lang="sk_sk">Niektoré streamy môžu vyžadovať aktívne internetové pripojenie.</disclaimer>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
