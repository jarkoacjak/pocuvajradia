<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.audio.pocuvam.radio" name="Počúvam Rádio" version="1.0.2" provider-name="Jarko">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.urllib3" version="1.26.4"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>audio</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="sk">Slovenské a České rádio stanice</summary>
        <description lang="sk">Doplnok pre počúvanie slovenských rádio staníc vrátane V2Beat, Záhoráckeho rádia a regionálnych staníc.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
